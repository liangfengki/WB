# 火山方舟 API 配置 (已弃用，保留兼容)
ARK_API_KEY=your_api_key_here
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=doubao-seedream-5-lite

# 云雾 AI API 配置 (实际使用)
YUNWU_API_KEYS=sk-xxx,sk-yyy
YUNWU_BASE_URL=https://api.yunwu.ai/v1
YUNWU_MODEL=gemini-3.1-flash-image-preview

# 生成配置
OUTPUT_SIZE=1024
CONCURRENCY=3
MAX_RETRIES=3
IMAGES_PER_PRODUCT=3

# OCR 配置
OCR_LANG=ch_sim
ENABLE_TEXT_OVERLAY=true

# 安全配置
SECRET_KEY=your-secret-key-here
FLASK_ENV=production

# 路径配置
INPUT_DIR=./input
OUTPUT_DIR=./output
LOG_DIR=./logs
UPLOAD_DIR=./uploads
